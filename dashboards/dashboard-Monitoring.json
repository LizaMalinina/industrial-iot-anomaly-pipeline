  "pages": [
    {
      "name": "Live Telemetry Overview",
      "id": "33017b45-5b07-4deb-9380-082fa794df68"
    },
    {
      "name": "Anomaly Detection",
      "id": "1122f4f9-9f82-4dd7-8c8e-b36d4e00258b"
    },
    {
      "name": "Device Health",
      "id": "8b08b4f6-a59a-46c0-93a9-bf524e5e1bde"
    }
  ],
  "queries": [
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "8b6f1458-23a7-4d54-83a4-570ddc5636ef"
      },
      "text": "SensorReadings\r\n| where timestamp > ago(1h)\r\n| project timestamp, temperature_c, device_id\r\n| order by timestamp asc",
      "id": "750f2298-37b0-4e98-be99-955294dfcf28",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "8b6f1458-23a7-4d54-83a4-570ddc5636ef"
      },
      "text": "SensorReadings\r\n| where timestamp > ago(1h)\r\n| project timestamp, vibration_raw, device_id\r\n| order by timestamp asc",
      "id": "1e76c87c-bb3c-441c-b602-b5364e014d45",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "8b6f1458-23a7-4d54-83a4-570ddc5636ef"
      },
      "text": "SensorReadings\r\n| summarize arg_max(timestamp, temperature_c) by device_id\r\n| project device_id, temperature_c, timestamp",
      "id": "0590ff16-01cf-4699-ba9d-44de5aa368f5",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "8b6f1458-23a7-4d54-83a4-570ddc5636ef"
      },
      "text": "SensorReadings\r\n| summarize arg_max(timestamp, vibration_raw) by device_id\r\n| project device_id, vibration_raw, timestamp",
      "id": "a4f18dfe-60ce-4218-a7a3-97404493f4dd",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "8b6f1458-23a7-4d54-83a4-570ddc5636ef"
      },
      "text": "SensorReadings\r\n| where timestamp > ago(1h)\r\n| summarize MessageCount = count()",
      "id": "bb483fc0-3ec4-47b2-81aa-62907c531236",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "8b6f1458-23a7-4d54-83a4-570ddc5636ef"
      },
      "text": "SensorReadings\r\n| where timestamp > ago(24h)\r\n| summarize MessageCount = count()",
      "id": "436a496d-7ffe-41fe-8424-6b0cbf802458",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "8b6f1458-23a7-4d54-83a4-570ddc5636ef"
      },
      "text": "let timeRange = ago(6h);\r\nlet readings = SensorReadings\r\n| where timestamp > timeRange\r\n| project timestamp, value = temperature_c, series = \"Normal Reading\", device_id;\r\nlet anomalies = SensorAnomalies\r\n| where event_timestamp > timeRange and temperature_is_anomaly == 1\r\n| project timestamp = event_timestamp, value = temperature_c, series = \"Anomaly\", device_id;\r\nunion readings, anomalies\r\n| order by timestamp asc",
      "id": "909ecaed-1cd4-4003-bee4-2d1e60d4a262",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "8b6f1458-23a7-4d54-83a4-570ddc5636ef"
      },
      "text": "let timeRange = ago(6h);\r\nlet readings = SensorReadings\r\n| where timestamp > timeRange\r\n| project timestamp, value = toreal(vibration_raw), series = \"Normal Reading\", device_id;\r\nlet anomalies = SensorAnomalies\r\n| where event_timestamp > timeRange and vibration_is_anomaly == 1\r\n| project timestamp = event_timestamp, value = toreal(vibration_raw), series = \"Anomaly\", device_id;\r\nunion readings, anomalies\r\n| order by timestamp asc",
      "id": "c1f1ce33-338c-4d48-b0f5-adec2f14cf87",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "8b6f1458-23a7-4d54-83a4-570ddc5636ef"
      },
      "text": "SensorAnomalies\r\n| where event_timestamp > ago(24h)\r\n| summarize\r\n    TemperatureAnomalies = countif(temperature_is_anomaly == 1),\r\n    VibrationAnomalies = countif(vibration_is_anomaly == 1)\r\n| project-rename ['Temperature'] = TemperatureAnomalies, ['Vibration'] = VibrationAnomalies\r\n| evaluate narrow()\r\n| project-rename AnomalyType = Column, Count = Value",
      "id": "9cdb42df-ea82-428b-a15f-53f922d6511a",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "8b6f1458-23a7-4d54-83a4-570ddc5636ef"
      },
      "text": "SensorAnomalies\r\n| extend SensorType = case(\r\n    temperature_is_anomaly == 1 and vibration_is_anomaly == 1, \"Both\",\r\n    temperature_is_anomaly == 1, \"Temperature\",\r\n    vibration_is_anomaly == 1, \"Vibration\",\r\n    \"Unknown\")\r\n| extend AnomalyScore = iff(temperature_is_anomaly == 1, temperature_anomaly_score, vibration_anomaly_score)\r\n| extend MeasureValue = iff(temperature_is_anomaly == 1, temperature_c, toreal(vibration_raw))\r\n| project event_timestamp, device_id, SensorType, MeasureValue, AnomalyScore, temperature_anomaly_score, vibration_anomaly_score\r\n| top 20 by event_timestamp desc",
      "id": "1957e8e5-ef97-4de8-92d3-7efaad507a2a",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "8b6f1458-23a7-4d54-83a4-570ddc5636ef"
      },
      "text": "SensorAnomalies\r\n| where event_timestamp > ago(24h)\r\n| summarize\r\n    TemperatureAnomalies = countif(temperature_is_anomaly == 1),\r\n    VibrationAnomalies = countif(vibration_is_anomaly == 1)\r\n    by bin(event_timestamp, 1h)\r\n| order by event_timestamp asc",
      "id": "d8cfe2fe-31a1-4637-9b1e-7907f6c3c48f",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "8b6f1458-23a7-4d54-83a4-570ddc5636ef"
      },
      "text": "SensorReadings\r\n| summarize\r\n    LastSeen = max(timestamp),\r\n    TotalMessages = count(),\r\n    LastTemperature = arg_max(timestamp, temperature_c),\r\n    LastVibration = arg_max(timestamp, vibration_raw)\r\n    by device_id\r\n| extend TimeSinceLastSeen = now() - LastSeen\r\n| extend Status = iff(TimeSinceLastSeen < 5m, '🟢 Online', iff(TimeSinceLastSeen < 30m, '🟡 Stale', '🔴 Offline'))\r\n| project device_id, Status, LastSeen, TimeSinceLastSeen, TotalMessages\r\n| order by LastSeen desc",
      "id": "5424672d-5ad0-4137-8aea-2e5833fb546b",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "8b6f1458-23a7-4d54-83a4-570ddc5636ef"
      },
      "text": "SensorReadings\r\n| where timestamp > ago(1h)\r\n| summarize MessageCount = count() by bin(timestamp, 1m), device_id\r\n| order by timestamp asc",
      "id": "87e15db8-d94b-4f62-ac57-dd93e129e6dc",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
